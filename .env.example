# Oura Ring personal access token
# Get yours at: https://cloud.ouraring.com/personal-access-tokens
OURA_TOKEN=your_oura_token_here

# TRMNL private plugin UUID
# Get yours at: https://trmnl.com/plugin_settings (create a Private Plugin, copy the UUID from the webhook URL)
TRMNL_PLUGIN_UUID=your_trmnl_plugin_uuid_here
